{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "main 窗口的默认权限：核心 API + 自定义 invoke。login 窗口走 127.0.0.1 桥不需要 capability。",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default"
  ]
}
