{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zero-desktop",
  "version": "0.2.1",
  "identifier": "com.jmobserver.zero-desktop",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "zero-desktop",
        "url": "index.html",
        "width": 800,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$LOCALDATA/zero-desktop/**",
          "$DATA/zero-desktop/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"],
    "category": "DeveloperTool",
    "shortDescription": "Unified desktop shell for English learning, speech recognition and Cookie management.",
    "longDescription": "zero-desktop is the unified Tauri 2 shell that hosts English listening, speech ASR and Cookie capture modules."
  }
}
